<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>LaunchBackground</string>
    </dict>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Pulse reads your photos to understand moments and emotions in your life. All analysis happens on your device — your photos never leave your phone.</string>
    <key>NSCameraUsageDescription</key>
    <string>Pulse uses your camera to capture moments you'd like to reflect on. Photos are stored locally and analyzed on-device.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Pulse records voice notes to understand how you're feeling through your voice and words. All recordings stay on your device.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Pulse transcribes your voice notes to analyze emotional content. Speech recognition happens on-device.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>Pulse reads your calendar to find patterns between your schedule and emotional wellbeing. Calendar data stays private on your device.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>Pulse can read health data to correlate physical activity with emotional patterns.</string>
</dict>
</plist>
